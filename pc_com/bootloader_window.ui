   <string notr="true">QWidget#bootloader_window {
    background: #f6f8fa;
}
QLabel#boot_title {
    color: #0f172a;
    font: 700 17pt "Segoe UI";
}
QLabel[stepState="done"] {
    background: #dcfce7;
    border: 1px solid #86efac;
    color: #14532d;
}
QLabel[stepState="active"] {
    background: #dbeafe;
    border: 1px solid #93c5fd;
    color: #1e3a8a;
}
QLabel[stepState="pending"] {
    background: #ffffff;
    border: 1px solid #cbd5e1;
    color: #475569;
}
QLineEdit, QTextEdit {
    border: 1px solid #cbd5e1;
    border-radius: 5px;
    padding: 6px;
    background: #ffffff;
}
QToolButton {
    border: 1px solid #b8c4d2;
    border-radius: 5px;
    padding: 6px 12px;
    background: #ffffff;
}
QToolButton:hover {
    background: #f1f5f9;
}
QToolButton#btn_primary {
    background: #2563eb;
    border-color: #1d4ed8;
    color: white;
    font-weight: 700;
}</string>
